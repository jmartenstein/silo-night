h2 Shows

div#showbox.border

  div#show.header
    form
      input#show-search.addtext type="text" placeholder="Name..." autocomplete="off"
      input.addbutton type="button" value="Add"
    div#suggestions style="position: relative;"

  ul#show.list
    - @shows.each do |s|
      li
        span.name = s.name
        span.runtime = " (#{s.runtime})"

h2 Availability

div#availbox.border
  form action="/user/#{@user.name}/availability" method="POST"
    table
      thead
        tr
          th Day
          th Enabled
          th Minutes
      tbody
        - ["Monday", "Tuesday", "Wednesday", "Thursday", "Friday", "Saturday", "Sunday"].each do |day|
          - abbr = @user.day_to_abbr(day)
          tr
            td = day
            td
              input type="checkbox" name="days[]" value=abbr checked=@user.day_enabled?(abbr)
            td
              input type="number" name="time_#{abbr}" value=@user.day_time(abbr) min="0" step="5"
    input type="submit" value="Save Availability"

script src="/javascript/default.js"
